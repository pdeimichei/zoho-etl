# Zoho ETL — configuration template
# Copy this file to ~/.zoho-etl/config.ini and fill in your values.
# Never commit config.ini to git (it contains credentials).

[paths]
# Folder where input files are placed and output is written
working_folder =

[files]
# Input file names (must be present in working_folder)
input_quotes  = Export002.csv
input_listino = Listino09.csv
input_gadget  = Gadget.csv
input_clienti = Clienti09.csv

# Output file name (written to working_folder)
output_file = ImportSO.csv

[email]
# Azure AD app registration credentials (OAuth2 Client Credentials flow)
# Register at: Azure Portal > Azure Active Directory > App registrations
# Required API permission: Microsoft Graph > Application permission > Mail.Send
# After granting admin consent, create a client secret under "Certificates & secrets".
# IMPORTANT: protect this file — chmod 600 ~/.zoho-etl/config.ini
tenant_id     =
client_id     =
client_secret =

# The licensed Exchange mailbox the app sends FROM (must be in the same tenant)
from_address  =

# Comma-separated list of recipient addresses
recipients = colleague1@company.com, colleague2@company.com, colleague3@company.com, colleague4@company.com

# Prefix used in the email subject line
subject_prefix = Sales Orders
